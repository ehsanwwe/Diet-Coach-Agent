# ============================================================
# Diet Coach Agent — Frontend Environment Variables
# ============================================================
# Copy this file to frontend/.env.local and fill in values.
# NEVER commit frontend/.env.local to git.
# Variables starting with NEXT_PUBLIC_ are exposed to the browser.
# ============================================================

# ── App Identity ──────────────────────────────────────────────
# App name shown in browser tab and PWA install prompt.
NEXT_PUBLIC_APP_NAME="مربی تغذیه | Diet Coach"

# ── API Configuration ─────────────────────────────────────────
# Base URL of the FastAPI backend. No trailing slash.
# Development: http://localhost:8000
# Production:  https://your-backend.example.com
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ── i18n Configuration ────────────────────────────────────────
# Default locale served when no cookie or Accept-Language preference is detected.
# Must be one of NEXT_PUBLIC_SUPPORTED_LOCALES.
# fa = Persian (RTL, default)  |  en = English (LTR)  |  ar = Arabic (RTL)
NEXT_PUBLIC_DEFAULT_LOCALE=fa

# Comma-separated list of supported locale codes.
# Used by the language switcher and middleware validation.
NEXT_PUBLIC_SUPPORTED_LOCALES=fa,en,ar

# ── Feature Flags ─────────────────────────────────────────────
# When true, Phase 5 onboarding video gate shows a "Mark as watched" button
# instead of requiring actual video playback. Development only.
NEXT_PUBLIC_ENABLE_DEV_VIDEO_BYPASS=true
