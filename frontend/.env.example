# ============================================================
# Diet Coach Agent — Frontend Environment Variables
# ============================================================
# Copy this file to frontend/.env.local and fill in values.
# NEVER commit frontend/.env.local to git.
# Variables starting with NEXT_PUBLIC_ are exposed to the browser.
# ============================================================

# ── API Configuration ─────────────────────────────────────────
# URL of the backend API. Used by Next.js for server-side fetches.
# In development: http://localhost:8000
# In production: https://your-backend.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── App Configuration ─────────────────────────────────────────
# Default locale if none is detected from cookie or Accept-Language.
# One of: fa (Persian/RTL), en (English/LTR), ar (Arabic/RTL)
NEXT_PUBLIC_DEFAULT_LOCALE=fa
