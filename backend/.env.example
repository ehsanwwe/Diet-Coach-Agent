# ============================================================
# Diet Coach Agent — Backend Environment Variables
# ============================================================
# Copy this file to backend/.env and fill in values.
# NEVER commit backend/.env to git.
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_NAME="Diet Coach Agent"
APP_VERSION="0.1.0"
# Set to "production" in production; affects debug output
ENVIRONMENT=development
DEBUG=false

# ── Security (REQUIRED) ──────────────────────────────────────
# REQUIRED: Server will refuse to start without this.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# JWT token expiry in minutes (default: 7 days = 10080 minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Database ─────────────────────────────────────────────────
# SQLite path relative to backend/ directory.
# Run: alembic upgrade head (from backend/) to initialize.
DATABASE_URL=sqlite+pysqlite:///./app.db

# ── CORS Origins ─────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Development: http://localhost:3000
# Production: https://your-deployed-frontend.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Authentication / OTP ────────────────────────────────────
# OTP code accepted in development mode (bypasses SMS).
# Set to a random value or remove in production.
DEV_OTP_CODE=123456

# OTP validity window in minutes.
OTP_EXPIRE_MINUTES=5

# SMS provider to use. "mock" logs OTPs to console (dev only).
# Future values: kavenegar, twilio
SMS_PROVIDER=mock

# ── AI Provider ──────────────────────────────────────────────
# Which AI provider to use.
# "mock"   — deterministic Persian responses, no API key needed (default for dev/offline)
# "openai" — real AI via OpenAI API (requires OPENAI_API_KEY + SOCKS5 proxy)
AI_PROVIDER=mock

# Use OpenAI in production:
# AI_PROVIDER=openai

# ── OpenAI ───────────────────────────────────────────────────
# Required when AI_PROVIDER=openai. Leave empty for mock mode.
#
# OPENAI_API_KEY
#   Your OpenAI secret key. Never commit this file with a real key.
#   Place your real key only in backend/.env (which is gitignored).
OPENAI_API_KEY=sk-your-openai-api-key-here

# OPENAI_BASE_URL
#   OpenAI API base URL. Change only if using a compatible proxy/gateway.
OPENAI_BASE_URL=https://api.openai.com/v1

# OPENAI_MODEL
#   Model to use. gpt-4.1-nano is fast and low-cost; suitable for nutrition coaching.
#   Other options: gpt-4.1-mini, gpt-4o-mini
OPENAI_MODEL=gpt-4.1-nano

# OPENAI_TIMEOUT_SECONDS
#   HTTP request timeout in seconds (covers the full response, including streaming wait).
OPENAI_TIMEOUT_SECONDS=120

# OPENAI_MAX_RETRIES
#   Retry attempts on transient errors (429, 5xx). Set to 0 to disable retries.
OPENAI_MAX_RETRIES=2

# OPENAI_TEMPERATURE
#   Sampling temperature. 0.0=deterministic, 1.0=creative.
#   0.3 is recommended for grounded nutrition advice.
OPENAI_TEMPERATURE=0.3

# OPENAI_MAX_TOKENS
#   Maximum tokens in each AI response. Increase for longer meal plans.
OPENAI_MAX_TOKENS=2048

# OPENAI_CONTEXT_MAX_MESSAGES
#   Maximum conversation messages included in each AI request.
#   Oldest messages are pruned when this limit is exceeded.
OPENAI_CONTEXT_MAX_MESSAGES=24

# ── OpenAI SOCKS5 Proxy (REQUIRED for OpenAI) ────────────────
# OpenAI requests are BLOCKED unless a SOCKS5 proxy is configured.
# This is the default-safe mode — no direct outbound calls to OpenAI.
#
# OPENAI_REQUIRE_PROXY
#   true  (default) — block OpenAI calls unless OPENAI_PROXY_URL is set.
#   false — allow direct calls (not recommended; set only if proxy is unavailable).
OPENAI_REQUIRE_PROXY=true

# OPENAI_PROXY_URL
#   SOCKS5 proxy host and port (no credentials here).
#   Use socks5:// if proxy resolves DNS locally.
#   Use socks5h:// if DNS should also go through the proxy (recommended for privacy).
#   Leave empty to block OpenAI calls (AI_PROVIDER=mock will be used instead).
OPENAI_PROXY_URL=socks5://your-proxy-host:10810

# If DNS must also go through the proxy, use:
# OPENAI_PROXY_URL=socks5h://your-proxy-host:10810

# OPENAI_PROXY_USER / OPENAI_PROXY_PASS
#   Optional SOCKS5 credentials.
#   When both are set, the backend constructs socks5://user:pass@host:port internally.
#   Special characters in the password (e.g. / @ : #) are percent-encoded automatically.
#   Leave both empty for unauthenticated proxies.
OPENAI_PROXY_USER=
OPENAI_PROXY_PASS=

# ── Audio Storage (Phase 6) ──────────────────────────────────
# AUDIO_STORAGE_PATH
#   Local directory where uploaded audio files are stored.
#   Relative path resolved from backend/ directory. Ignored by git.
AUDIO_STORAGE_PATH=./storage/audio

# MAX_AUDIO_UPLOAD_MB
#   Maximum allowed audio upload size in megabytes.
MAX_AUDIO_UPLOAD_MB=20

# ALLOWED_AUDIO_MIME_TYPES
#   Comma-separated list of accepted MIME types for audio uploads.
#   Browser MediaRecorder uses audio/webm (Chrome) or audio/mp4 (iOS Safari).
ALLOWED_AUDIO_MIME_TYPES=audio/webm,audio/ogg,audio/mp4,audio/mpeg,audio/wav
