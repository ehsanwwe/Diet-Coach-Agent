# ============================================================
# Diet Coach Agent — Backend Environment Variables
# ============================================================
# Copy this file to backend/.env and fill in values.
# NEVER commit backend/.env to git.
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_NAME="Diet Coach Agent"
APP_VERSION="0.1.0"
# Set to "production" in production; affects debug output
ENVIRONMENT=development
DEBUG=false

# ── Security (REQUIRED) ──────────────────────────────────────
# REQUIRED: Server will refuse to start without this.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# JWT token expiry in minutes (default: 7 days = 10080 minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Database ─────────────────────────────────────────────────
# SQLite path relative to backend/ directory.
# Run: alembic upgrade head (from backend/) to initialize.
DATABASE_URL=sqlite+pysqlite:///./app.db

# ── CORS Origins ─────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Development: http://localhost:3000
# Production: https://your-deployed-frontend.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Authentication / OTP ────────────────────────────────────
# OTP code accepted in development mode (bypasses SMS).
# Set to a random value or remove in production.
DEV_OTP_CODE=123456

# OTP validity window in minutes.
OTP_EXPIRE_MINUTES=5

# SMS provider to use. "mock" logs OTPs to console (dev only).
# Future values: kavenegar, twilio
SMS_PROVIDER=mock

# ── AI Provider Selection (Phase 7) ─────────────────────────
# Which AI provider to use.
# "mock"     — deterministic Persian responses, no API key needed (default for dev)
# "openclaw" — real AI via OpenAI-compatible endpoint (requires OPENCLAW_BASE_URL)
# If "openclaw" is selected but OPENCLAW_BASE_URL is empty, falls back to mock silently.
AI_PROVIDER=mock

# ── OpenClaw AI Provider ─────────────────────────────────────
# All 10 OPENCLAW_* variables. Required for real AI responses.
# When OPENCLAW_BASE_URL is not set, app uses MockAIProvider (no error).
#
# OPENCLAW_BASE_URL
#   The base URL of the OpenAI-compatible AI endpoint.
#   Example: https://api.openai.com  or  https://your-openclaw-endpoint.com
#   Leave empty to use MockAIProvider (deterministic Persian responses).
OPENCLAW_BASE_URL=

# OPENCLAW_API_KEY
#   API key for authenticating requests to the AI endpoint.
#   Sent as: Authorization: Bearer <key>
#   Leave empty if endpoint does not require auth (e.g., local LLM).
OPENCLAW_API_KEY=

# OPENCLAW_MODEL
#   Model name sent in the request body.
#   Example: gpt-4o, gpt-3.5-turbo, llama3, mistral
OPENCLAW_MODEL=openclaw/main

# OPENCLAW_CHAT_COMPLETIONS_PATH
#   Path appended to OPENCLAW_BASE_URL for chat completions.
#   OpenAI-compatible: /v1/chat/completions
OPENCLAW_CHAT_COMPLETIONS_PATH=/v1/chat/completions

# OPENCLAW_TIMEOUT_SECONDS
#   HTTP request timeout in seconds. Requests exceeding this are cancelled.
#   Increase for slow models; decrease for fast local LLMs.
OPENCLAW_TIMEOUT_SECONDS=120

# OPENCLAW_MAX_RETRIES
#   Number of retry attempts on transient network errors (429, 5xx).
#   Set to 0 to disable retries.
OPENCLAW_MAX_RETRIES=2

# OPENCLAW_TEMPERATURE
#   Sampling temperature for AI responses. 0.0=deterministic, 1.0=creative.
#   Nutrition advice: 0.6-0.8 recommended for varied but grounded responses.
OPENCLAW_TEMPERATURE=0.3

# OPENCLAW_MAX_TOKENS
#   Maximum tokens in each AI response.
#   Increase for longer meal plans; decrease to reduce cost.
OPENCLAW_MAX_TOKENS=2048

# OPENCLAW_CONTEXT_MAX_MESSAGES
#   Maximum number of conversation messages sent in each AI request.
#   When exceeded, oldest messages are pruned (context window management).
#   Increase for richer context; decrease to reduce token cost.
OPENCLAW_CONTEXT_MAX_MESSAGES=24

# OPENCLAW_CONTEXT_SUMMARY_ENABLED
#   When true: generates a rolling summary when OPENCLAW_CONTEXT_MAX_MESSAGES
#   is reached, stores it in ChatSession.summary, and injects it into the
#   next session's system prompt prefix.
#   When false: oldest messages are pruned without summarization.
OPENCLAW_CONTEXT_SUMMARY_ENABLED=true

# ── Audio Storage (Phase 6) ──────────────────────────────────
# AUDIO_STORAGE_PATH
#   Local directory where uploaded audio files are stored.
#   Relative path resolved from backend/ directory. Ignored by git.
AUDIO_STORAGE_PATH=./storage/audio

# MAX_AUDIO_UPLOAD_MB
#   Maximum allowed audio upload size in megabytes.
MAX_AUDIO_UPLOAD_MB=20

# ALLOWED_AUDIO_MIME_TYPES
#   Comma-separated list of accepted MIME types for audio uploads.
#   Browser MediaRecorder uses audio/webm (Chrome) or audio/mp4 (iOS Safari).
ALLOWED_AUDIO_MIME_TYPES=audio/webm,audio/ogg,audio/mp4,audio/mpeg,audio/wav
