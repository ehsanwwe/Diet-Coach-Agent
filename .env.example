# ============================================================
# Diet Coach Agent — Root Environment Variables
# ============================================================
# This file documents cross-service environment variables.
#
# For service-specific variables, see:
#   backend/.env.example   — Backend (FastAPI) variables
#   frontend/.env.example  — Frontend (Next.js) variables
#
# Copy this file to .env at repository root for any shared
# orchestration tools (docker-compose, CI, etc.).
# ============================================================

# ── Development Ports ─────────────────────────────────────────
# Backend API server port (uvicorn)
BACKEND_PORT=8000

# Frontend dev server port (Next.js)
FRONTEND_PORT=3000

# ── Cross-Service ─────────────────────────────────────────────
# Used if running both services via a shared script or docker-compose.
# Individual service .env files take precedence for service-specific vars.

# Backend API URL (referenced by frontend when building)
NEXT_PUBLIC_API_URL=http://localhost:8000
